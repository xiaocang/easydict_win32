                "-p:Platform=x64",
                "-p:BuildWorkerOutputs=false",
                "-p:WindowsAppSdkAutoInitialize=false",
                "--no-restore",
                "--filter",
                "FullyQualifiedName~LongDocWorkerPipelineTests"
            ],
            "problemMatcher": "$msCompile",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "test-pdf-worker-export",
            "command": "dotnet",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/dotnet"
            },
            "dependsOn": "ensure-build-submodules",
            "dependsOrder": "sequence",
            "args": [
                "test",
                "${workspaceFolder}/dotnet/tests/Easydict.WinUI.Tests/Easydict.WinUI.Tests.csproj",
                "-p:Platform=x64",
                "-p:BuildWorkerOutputs=false",
                "-p:WindowsAppSdkAutoInitialize=false",
                "--no-restore",
                "--filter",
                "FullyQualifiedName~LongDocWorkerPipelineTests|FullyQualifiedName~LongDocumentTranslationServiceReviewFixTests|FullyQualifiedName~DocumentExportServiceTests|FullyQualifiedName~MuPdfExportServiceSpacingTests"
            ],
            "problemMatcher": "$msCompile",
            "group": "test",
            "presentation": {
                "reveal": "always",
