{
    "version": "2.0.0",
    "tasks": [
        // ============================================
        // Build Tasks
        // ============================================
        {
            "label": "ensure-build-submodules",
            "command": "powershell.exe",
            "type": "shell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/dotnet/scripts/ensure-build-submodules.ps1",
                "-WorkspaceRoot",
                "${workspaceFolder}"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "build",
            "command": "dotnet",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/dotnet"
            },
            "dependsOn": "ensure-build-submodules",
            "dependsOrder": "sequence",
            "args": [
                "build",
                "${workspaceFolder}/dotnet/src/Easydict.WinUI/Easydict.WinUI.csproj",
                "-p:Platform=x64",
                "-p:BuildWorkerOutputs=true",
                "-p:WindowsPackageType=None",
                "-p:SkipPriFileVerification=true",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary,ForceNoAlign"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "build-debug",
            "command": "dotnet",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/dotnet"
            },
            "dependsOn": "ensure-build-submodules",
            "dependsOrder": "sequence",
            "args": [
                "build",
                "${workspaceFolder}/dotnet/src/Easydict.WinUI/Easydict.WinUI.csproj",
                "-p:Platform=x64",
                "-p:BuildWorkerOutputs=true",
                "--configuration",
                "Debug",
                "-p:WindowsPackageType=None",
                "-p:SkipPriFileVerification=true",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary,ForceNoAlign"
            ],
            "problemMatcher": "$msCompile",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
