<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <Color x:Key="MinimalBackgroundColor">#FFFFFF</Color>
            <Color x:Key="MinimalSurfaceColor">#FFFFFF</Color>
            <Color x:Key="MinimalLineColor">#999999</Color>
            <Color x:Key="MinimalStrongLineColor">#000000</Color>
            <Color x:Key="MinimalTextColor">#111111</Color>
            <Color x:Key="MinimalSecondaryTextColor">#666666</Color>

            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource MinimalBackgroundColor}" />
            <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="{StaticResource MinimalLineColor}" />

            <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource MinimalTextColor}" />
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource MinimalSecondaryTextColor}" />
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource MinimalSecondaryTextColor}" />
            <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="{StaticResource MinimalTextColor}" />
            <SolidColorBrush x:Key="SystemFillColorSuccessBrush" Color="{StaticResource MinimalTextColor}" />
            <SolidColorBrush x:Key="SystemFillColorCriticalBrush" Color="{StaticResource MinimalTextColor}" />

            <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#F7F7F7" />
            <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource MinimalLineColor}" />
            <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{StaticResource MinimalLineColor}" />

            <SolidColorBrush x:Key="ButtonBackground" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#F7F7F7" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#EEEEEE" />
            <SolidColorBrush x:Key="ButtonForeground" Color="{StaticResource MinimalTextColor}" />
            <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource MinimalLineColor}" />
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource MinimalStrongLineColor}" />
            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="{StaticResource MinimalStrongLineColor}" />

            <SolidColorBrush x:Key="ComboBoxBackground" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#F7F7F7" />
            <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{StaticResource MinimalLineColor}" />
            <SolidColorBrush x:Key="ComboBoxForeground" Color="{StaticResource MinimalTextColor}" />
            <SolidColorBrush x:Key="TextControlBackground" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource MinimalLineColor}" />
            <SolidColorBrush x:Key="TextControlForeground" Color="{StaticResource MinimalTextColor}" />
            <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="{StaticResource MinimalSecondaryTextColor}" />

            <CornerRadius x:Key="ControlCornerRadius">0</CornerRadius>
            <CornerRadius x:Key="OverlayCornerRadius">0</CornerRadius>
            <CornerRadius x:Key="EasydictCardCornerRadius">0</CornerRadius>
            <CornerRadius x:Key="EasydictControlCornerRadius">0</CornerRadius>
            <CornerRadius x:Key="EasydictRoundButtonCornerRadius">0</CornerRadius>
            <CornerRadius x:Key="EasydictStatusCornerRadius">0</CornerRadius>
            <Thickness x:Key="EasydictCardBorderThickness">1</Thickness>
            <Thickness x:Key="EasydictIconButtonBorderThickness">1</Thickness>

            <SolidColorBrush x:Key="MainViewBackgroundBrush" Color="{StaticResource MinimalBackgroundColor}" />
            <SolidColorBrush x:Key="MainBorderBrush" Color="{StaticResource MinimalStrongLineColor}" />
            <SolidColorBrush x:Key="QueryViewBackgroundBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="QueryTextBrush" Color="{StaticResource MinimalTextColor}" />
            <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="ResultViewBackgroundBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="ServiceResultHeaderBackgroundBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="ServiceResultHeaderHoverBackgroundBrush" Color="#F7F7F7" />
            <SolidColorBrush x:Key="ServiceResultHeaderForegroundBrush" Color="{StaticResource MinimalTextColor}" />
            <SolidColorBrush x:Key="ServiceResultHeaderSecondaryForegroundBrush" Color="{StaticResource MinimalSecondaryTextColor}" />
            <SolidColorBrush x:Key="ButtonHoverBrush" Color="#F7F7F7" />
            <SolidColorBrush x:Key="BlueAccentBrush" Color="{StaticResource MinimalTextColor}" />
            <SolidColorBrush x:Key="BlueTintBrush" Color="{StaticResource MinimalTextColor}" />
            <SolidColorBrush x:Key="AddMinusBackgroundBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="ListBorderBrush" Color="{StaticResource MinimalLineColor}" />
            <SolidColorBrush x:Key="ActionButtonIconBrush" Color="{StaticResource MinimalTextColor}" />
            <SolidColorBrush x:Key="StatusConnectedBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="StatusDisconnectedBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="StatusErrorBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="PhoneticBadgeBackgroundBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="PhoneticBadgeTextBrush" Color="{StaticResource MinimalTextColor}" />
            <SolidColorBrush x:Key="PosTagBackgroundBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="PosTagTextBrush" Color="{StaticResource MinimalTextColor}" />
            <SolidColorBrush x:Key="ExampleTextBrush" Color="{StaticResource MinimalSecondaryTextColor}" />
            <SolidColorBrush x:Key="SettingsTabBackgroundBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="SettingsTabBorderBrush" Color="{StaticResource MinimalLineColor}" />
            <SolidColorBrush x:Key="SettingsTabForegroundBrush" Color="{StaticResource MinimalTextColor}" />
            <SolidColorBrush x:Key="SettingsTabSelectedBackgroundBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="SettingsTabSelectedBorderBrush" Color="{StaticResource MinimalStrongLineColor}" />
            <SolidColorBrush x:Key="SettingsTabSelectedForegroundBrush" Color="{StaticResource MinimalTextColor}" />
            <SolidColorBrush x:Key="PopButtonBackgroundBrush" Color="{StaticResource MinimalSurfaceColor}" />
            <SolidColorBrush x:Key="PopButtonBorderBrush" Color="{StaticResource MinimalStrongLineColor}" />
            <SolidColorBrush x:Key="PopButtonForegroundBrush" Color="{StaticResource MinimalTextColor}" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
