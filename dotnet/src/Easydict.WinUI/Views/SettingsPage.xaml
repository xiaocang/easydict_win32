<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Easydict.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Easydict.WinUI.Views"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Themes/SettingsPageResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <local:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
            <local:BoolToCompactMarginConverter x:Key="BoolToCompactMarginConverter"/>
            <local:BoolToCompactFontSizeConverter x:Key="BoolToCompactFontSizeConverter"/>
            <local:BoolToItalicFontStyleConverter x:Key="BoolToItalicFontStyleConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <!-- Loading overlay (visible initially, hidden after init) -->
        <StackPanel x:Name="LoadingOverlay"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False"
                    Spacing="12">
            <ProgressRing x:Name="LoadingOverlayRing"
                    IsActive="True"
                    Width="32"
                    Height="32"/>
        </StackPanel>

        <ScrollViewer x:Name="MainScrollViewer"
                Padding="24"
                HorizontalScrollBarVisibility="Disabled"
                Visibility="Collapsed">
            <StackPanel x:Name="SettingsContentRoot"
                    Spacing="24"
                    Width="{Binding ViewportWidth, ElementName=MainScrollViewer}"
                    MaxWidth="1040"
                    HorizontalAlignment="Center">
                <!-- Header -->
                <Grid x:Name="HeaderSection">
                    <StackPanel Orientation="Horizontal"
                            Spacing="12">
                        <Button x:Name="BackButton"
                                AutomationProperties.AutomationId="BackButton"
                                AutomationProperties.Name="Back"
                                Click="OnBackClick"
                                Style="{StaticResource SettingsAccentButtonStyle}"
                                Padding="8">
                            <FontIcon Glyph="&#xE72B;"
                                    FontSize="16"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        </Button>
                        <TextBlock x:Name="SettingsHeaderText"
                                Text="Settings"
                                FontSize="28"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Settings Tabs -->
                <Grid>
                    <ItemsControl x:Name="SettingsTabsHost"
                                  HorizontalAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal"
                                               MaximumRowsOrColumns="7"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Click="OnSettingsTabClick"
                                        Loaded="OnSettingsTabButtonLoaded"
                                        Tag="{Binding Id}"
                                        AutomationProperties.AutomationId="{Binding AutomationId}"
                                        AutomationProperties.Name="{Binding Label}"
                                        Style="{StaticResource SettingsTabButtonStyle}"
                                        Width="86"
                                        Height="76"
                                        Margin="0,0,10,10"
                                        Padding="0"
                                        Background="{Binding Background}"
                                        BorderBrush="{Binding BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{ThemeResource EasydictControlCornerRadius}"
                                        Foreground="{Binding Foreground}"
                                        HorizontalAlignment="Left"
                                        ToolTipService.ToolTip="{Binding Tooltip}">
                                    <Grid>
                                        <StackPanel Spacing="6"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <FontIcon Glyph="{Binding IconGlyph}"
                                                      FontSize="22"
                                                      Foreground="{Binding Foreground}"
                                                      HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="12"
                                                       Foreground="{Binding Foreground}"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <Border
                                            Background="{Binding SelectedBackground}"
                                            BorderBrush="{Binding SelectedBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{ThemeResource EasydictControlCornerRadius}"
                                            Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                        <StackPanel Spacing="6"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <FontIcon Glyph="{Binding IconGlyph}"
                                                      FontSize="22"
                                                      Foreground="{Binding SelectedForeground}"
                                                      HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="12"
                                                       Foreground="{Binding SelectedForeground}"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid IsHitTestVisible="False"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Top"
                          Height="0"
                          Canvas.ZIndex="1">
                        <ProgressRing x:Name="SettingsTabSwitchRing"
                                      Width="20"
                                      Height="20"
                                      Margin="0,6,4,0"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Top"
                                      IsActive="False"
                                      Visibility="Collapsed"
                                      AutomationProperties.Name="Loading settings tab"/>
                    </Grid>
                </Grid>

                <Grid x:Name="TabContentHost">
                    <StackPanel x:Name="ServicesTabContent"
                                Spacing="24">
                    <!-- Service Overview -->
                    <StackPanel x:Name="EnabledServicesSection"
                            Spacing="12">
                        <StackPanel Orientation="Horizontal"
                                Spacing="8">
                            <TextBlock x:Name="EnabledServicesHeaderText"
                                    Text="Enabled Services"
                                    FontSize="18"
                                    FontWeight="SemiBold"/>
                            <FontIcon x:Name="EnabledServicesHelpIcon"
                                    Glyph="&#xE897;"
                                    FontSize="14"
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="EnabledServicesDescriptionText"
                                Text="Select which translation services to display in each window. Multiple services will run in parallel."
                                   FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal"
                                Spacing="8">
                            <Button x:Name="ImportMdxDictionaryButton"
                                    Content="Import MDX Dictionary"
                                    Click="OnImportMdxDictionaryClicked"
                                    Padding="10,4"/>
                            <TextBlock x:Name="ImportedMdxSummaryText"
                                       Text="No MDX dictionaries imported"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <!-- International Services Toggle -->
                        <Border Style="{StaticResource SettingsSectionStyle}"
                                Padding="12,8">
                            <StackPanel Spacing="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="EnableInternationalServicesHeaderText"
                                               Text="Enable International Services"
                                               FontSize="13"
                                               VerticalAlignment="Center"/>
                                    <ToggleSwitch x:Name="EnableInternationalServicesToggle"
                                                  Grid.Column="1"
                                                  Toggled="OnEnableInternationalServicesToggled"
                                                  MinWidth="0"
                                                  VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="EnableInternationalServicesDescriptionText"
                                           Text="Some services require international network access."
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Service Configuration -->
                    <StackPanel x:Name="ServiceConfigurationSection"
                            Spacing="12">
                        <StackPanel Orientation="Horizontal"
                                Spacing="8">
                            <TextBlock x:Name="ServiceConfigurationHeaderText"
                                    Text="Service Configuration"
                                    FontSize="18"
                                    FontWeight="SemiBold"/>
                            <FontIcon x:Name="ServiceConfigHelpIcon"
                                    Glyph="&#xE897;"
                                    FontSize="14"
                                      Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="ServiceConfigurationDescriptionText"
                                Text="Configure API keys, endpoints, and models for each translation service."
                                   FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <!-- DeepL -->
                        <Expander AutomationProperties.AutomationId="DeepLServiceExpander"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Tag="DeepL">
                            <Expander.Header>
                                <Grid>
                                    <TextBlock Text="DeepL"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="DeepLStatusText"
                                            Text="✓"
                                            FontWeight="SemiBold"
                                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                            HorizontalAlignment="Right"
                                            Margin="0,0,8,0"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="12"
                                    Padding="0,8">
                                <StackPanel Width="350"
                                            HorizontalAlignment="Left"
                                            Spacing="4">
                                    <TextBlock x:Name="DeepLKeyHeaderText"
                                               Text="API Key (Optional)"
                                               FontSize="14"/>
                                    <Grid>
                                        <PasswordBox x:Name="DeepLKeyBox"
                                                     HorizontalAlignment="Stretch"
                                                     Padding="12,5,40,5"
                                                     PlaceholderText="Enter your DeepL API key"
                                                     PasswordRevealMode="Hidden"/>
                                        <Button x:Name="DeepLKeyRevealButton"
                                                AutomationProperties.AutomationId="DeepLKeyRevealButton"
                                                Style="{StaticResource SettingsInlineIconButtonStyle}"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,0,6,0"
                                                Tag="{Binding ElementName=DeepLKeyBox}"
                                                Click="OnPasswordRevealButtonClick">
                                            <FontIcon Glyph="&#xE890;"
                                                      FontSize="14"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                                <CheckBox x:Name="DeepLFreeCheck"/>
                                <CheckBox x:Name="DeepLQualityCheck"/>
                                <TextBlock x:Name="DeepLDescriptionText"
                                           FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap"/>
                                <Button x:Name="TestDeepLButton"
                                        Content="Test"
                                        Click="OnTestDeepL"
                                        Padding="8,4"/>
                            </StackPanel>
                        </Expander>

                        <!-- Windows Local AI (Phi Silica, Foundry Local, and OpenVINO fallback) -->
                        <Expander x:Name="WindowsLocalAIExpander"
                                AutomationProperties.AutomationId="WindowsLocalAIExpander"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Tag="windows-local-ai">
                            <Expander.Header>
                                <Grid>
                                    <TextBlock x:Name="WindowsLocalAITitleText"
                                               Text="Windows Local AI"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="WindowsLocalAIStatusBadge"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,8,0"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="12"
                                    Padding="0,8">
                                <StackPanel Spacing="6"
                                            HorizontalAlignment="Left">
                                    <TextBlock x:Name="LocalAIProviderLabelText"
                                               Text="Provider"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <ComboBox x:Name="LocalAIProviderCombo"
                                              AutomationProperties.Name="Windows Local AI Provider"
                                              Width="520"
                                              Height="40"
                                              SelectionChanged="OnLocalAIProviderChanged">
                                        <ComboBoxItem x:Name="LocalAIProviderAutoItem"
                                                      Content="Auto (Phi Silica → Foundry Local → OpenVINO)"
                                                      Tag="Auto"/>
                                        <ComboBoxItem x:Name="LocalAIProviderWindowsAIItem"
                                                      Tag="WindowsAI">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8">
                                                <TextBlock x:Name="LocalAIProviderWindowsAILabelText"
                                                           Text="Phi Silica (Copilot+ PC)"/>
                                                <TextBlock x:Name="LocalAIProviderWindowsAIRatingText"
                                                           Text="★★★★★"
                                                           ToolTipService.ToolTip="Best quality when available."/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem x:Name="LocalAIProviderFoundryLocalItem"
                                                      Tag="FoundryLocal">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8">
                                                <TextBlock x:Name="LocalAIProviderFoundryLocalLabelText"
                                                           Text="Foundry Local"/>
                                                <TextBlock x:Name="LocalAIProviderFoundryLocalRatingText"
                                                           Text="★★★★"
                                                           ToolTipService.ToolTip="Good local LLM fallback."/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem x:Name="LocalAIProviderOpenVINOItem"
                                                      Tag="OpenVINO">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8">
                                                <TextBlock x:Name="LocalAIProviderOpenVINOLabelText"
                                                           Text="OpenVINO (NLLB-200)"/>
                                                <TextBlock x:Name="LocalAIProviderOpenVINORatingText"
                                                           Text="★★"
                                                           ToolTipService.ToolTip="Basic offline translation fallback."/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock x:Name="WindowsLocalAIDescriptionText"
                                           Text="Auto uses Phi Silica first, then Foundry Local, then OpenVINO/NLLB. No cloud API key."
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                                <StackPanel x:Name="WindowsLocalAIConfigPanel"
                                            Spacing="10">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <TextBlock x:Name="WindowsLocalAISectionTitleText"
                                                   Text="Phi Silica"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="WindowsLocalAISectionRatingText"
                                                   Text="★★★★★"
                                                   ToolTipService.ToolTip="Best quality when available."/>
                                    </StackPanel>
                                    <InfoBar x:Name="WindowsLocalAIStatusBar"
                                             AutomationProperties.AutomationId="WindowsLocalAIStatusBar"
                                             IsOpen="True"
                                             IsClosable="False"
                                             Severity="Informational"
                                             Title="Status"
                                             Message=""/>
                                    <Button x:Name="WindowsLocalAIPrepareButton"
                                            Content="Prepare model"
                                            Click="OnPreparePhiSilicaModel"
                                            Padding="14,0"
                                            Height="40"
                                            HorizontalAlignment="Left"
                                            Visibility="Collapsed"/>
                                    <StackPanel x:Name="WindowsLocalAIPrepareProgressPanel"
                                                Spacing="4"
                                                Visibility="Collapsed">
                                        <TextBlock x:Name="WindowsLocalAIPrepareProgressText"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                        <ProgressBar x:Name="WindowsLocalAIPrepareProgressBar"
                                                     Height="4"
                                                     IsIndeterminate="True"/>
                                        <HyperlinkButton x:Name="WindowsLocalAIWindowsUpdateLink"
                                                         Content="Track download progress in Windows Update"
                                                         NavigateUri="ms-settings:windowsupdate"
                                                         Padding="0"
                                                         MinHeight="0"
                                                         FontSize="12"
                                                         HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel x:Name="FoundryLocalConfigPanel"
                                            Spacing="10">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <TextBlock x:Name="FoundryLocalTitleText"
                                                   Text="Foundry Local"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="FoundryLocalRatingText"
                                                   Text="★★★★"
                                                   ToolTipService.ToolTip="Good local LLM fallback."/>
                                    </StackPanel>
                                    <TextBox x:Name="FoundryLocalEndpointBox"
                                             Header="Endpoint (optional)"
                                             PlaceholderText="Auto-detect from foundry service status"
                                             TextWrapping="NoWrap"/>
                                    <TextBox x:Name="FoundryLocalModelBox"
                                             Header="Model"
                                             Text="qwen2.5-0.5b"
                                             TextWrapping="NoWrap"/>
                                    <InfoBar x:Name="FoundryLocalStatusBar"
                                             IsOpen="True"
                                             IsClosable="False"
                                             Severity="Informational"
                                             Title="Status"
                                             Message=""/>
                                    <Button x:Name="FoundryLocalStartButton"
                                            Content="Start Foundry Local"
                                            Click="OnStartFoundryLocal"
                                            Padding="14,0"
                                            Height="40"
                                            HorizontalAlignment="Left"
                                            Visibility="Collapsed"/>
                                    <TextBlock x:Name="FoundryLocalDescriptionText"
                                               Text="Leave endpoint empty to auto-detect the local OpenAI-compatible endpoint."
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                    <HyperlinkButton x:Name="FoundryLocalInstallLink"
                                                     Content="Install Foundry Local"
                                                     HorizontalAlignment="Left"
                                                     Padding="0"/>
                                </StackPanel>
                                <StackPanel x:Name="OpenVinoConfigPanel"
                                            Spacing="10">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8"
                                                    HorizontalAlignment="Left">
                                            <TextBlock x:Name="OpenVinoTitleText"
                                                       Text="OpenVINO (local NLLB)"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock x:Name="OpenVinoRatingText"
                                                       Text="★★"
                                                       ToolTipService.ToolTip="Basic offline translation fallback."/>
                                        </StackPanel>
                                        <TextBlock x:Name="OpenVinoStatusBadge"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,0,8,0"
                                                   Visibility="Collapsed"/>
                                    </Grid>
                                    <InfoBar x:Name="OpenVinoStatusBar"
                                             IsOpen="True"
                                             IsClosable="False"
                                             Severity="Informational"
                                             Title="Status"
                                             Message=""/>
                                    <ProgressBar x:Name="OpenVinoDownloadProgress"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Visibility="Collapsed"/>
                                    <Button x:Name="OpenVinoDownloadButton"
                                            Content="Download model"
                                            Click="OnDownloadOpenVinoModel"
                                            Padding="14,0"
                                            Height="40"
                                            HorizontalAlignment="Left"
                                            Visibility="Collapsed"/>
                                    <TextBlock x:Name="OpenVinoDescriptionText"
                                               Text="OpenVINO runs NLLB-200 locally with ONNX Runtime. Hardware acceleration is best effort and falls back to CPU when needed."
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <!-- Ollama (Local) -->
                        <Expander HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Tag="Ollama">
                            <Expander.Header>
                                <Grid>
                                    <TextBlock Text="Ollama (Local LLM)"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="OllamaStatusText"
                                            Text="✓"
                                            FontWeight="SemiBold"
                                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                            HorizontalAlignment="Right"
                                            Margin="0,0,8,0"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="12"
                                    Padding="0,8">
                                <TextBox x:Name="OllamaEndpointBox"
                                        Header="Endpoint"
                                        Width="450"
                                         PlaceholderText="http://localhost:11434/v1/chat/completions"
                                        HorizontalAlignment="Left"/>
                                <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                    <ComboBox x:Name="OllamaModelCombo"
                                            Header="Model"
                                            Width="200"
                                            IsEditable="True"/>
                                    <Button x:Name="RefreshOllamaButton"
                                            Content="Refresh"
                                            Click="OnRefreshOllamaModels"
                                            VerticalAlignment="Bottom"
                                            Padding="12,6"/>
                                    <Button x:Name="TestOllamaButton"
                                            Content="Test"
                                            Click="OnTestOllama"
                                            VerticalAlignment="Bottom"
                                            Padding="8,4"/>
                                </StackPanel>
                                <TextBlock Text="Ollama must be running locally. Click Refresh to load available models."
                                           FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Expander>

                        <!-- OpenAI -->
                        <Expander HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Tag="OpenAI">
                            <Expander.Header>
                                <Grid>
                                    <TextBlock Text="OpenAI"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="OpenAIStatusText"
                                            Text="✓"
                                            FontWeight="SemiBold"
                                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                            HorizontalAlignment="Right"
                                            Margin="0,0,8,0"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="12"
                                    Padding="0,8">
                                <StackPanel Width="350"
                                            HorizontalAlignment="Left"
                                            Spacing="4">
                                    <TextBlock x:Name="OpenAIKeyHeaderText"
                                               Text="API Key"
                                               FontSize="14"/>
                                    <Grid>
                                        <PasswordBox x:Name="OpenAIKeyBox"
                                                     HorizontalAlignment="Stretch"
                                                     Padding="12,5,40,5"
                                                     PlaceholderText="sk-..."
                                                     PasswordRevealMode="Hidden"/>
                                        <Button x:Name="OpenAIKeyRevealButton"
                                                AutomationProperties.AutomationId="OpenAIKeyRevealButton"
                                                Style="{StaticResource SettingsInlineIconButtonStyle}"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,0,6,0"
                                                Tag="{Binding ElementName=OpenAIKeyBox}"
                                                Click="OnPasswordRevealButtonClick">
                                            <FontIcon Glyph="&#xE890;"
                                                      FontSize="14"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                                <TextBox x:Name="OpenAIEndpointBox"
                                        Header="Endpoint (Optional)"
                                        Width="450"
                                         PlaceholderText="https://api.openai.com/v1/responses"
                                        HorizontalAlignment="Left"/>
                                <ComboBox x:Name="OpenAIApiFormatCombo"
                                        Header="API Format"
                                        Width="280">
                                    <ComboBoxItem Content="Auto-detect"
                                            Tag="Auto"/>
                                    <ComboBoxItem Content="Responses API"
                                            Tag="Responses"/>
                                    <ComboBoxItem Content="Chat Completions API"
                                            Tag="ChatCompletions"/>
                                </ComboBox>
                                <TextBlock x:Name="OpenAIDetectedFormatText"
                                           FontSize="12"
                                           Visibility="Collapsed"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <ComboBox x:Name="OpenAIModelCombo"
                                        Header="Model"
                                        Width="280"
                                        IsEditable="True">
                                    <ComboBoxItem Content="gpt-5-mini"
                                            Tag="gpt-5-mini"/>
                                    <ComboBoxItem Content="gpt-5-nano"
                                            Tag="gpt-5-nano"/>
                                    <ComboBoxItem Content="gpt-5"
                                            Tag="gpt-5"/>
                                    <ComboBoxItem Content="gpt-4.1-mini"
                                            Tag="gpt-4.1-mini"/>
                                    <ComboBoxItem Content="gpt-4.1-nano"
                                            Tag="gpt-4.1-nano"/>
                                    <ComboBoxItem Content="gpt-4o-mini"
                                            Tag="gpt-4o-mini"/>
                                    <ComboBoxItem Content="gpt-4o"
                                            Tag="gpt-4o"/>
                                </ComboBox>
                                <TextBlock Text="Auto-detect picks /responses when the endpoint URL ends with that suffix; otherwise it uses /chat/completions. You can type a custom model name directly."
                                           FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Button x:Name="TestOpenAIButton"
                                        Content="Test"
                                        Click="OnTestOpenAI"
                                        Padding="8,4"/>
                            </StackPanel>
                        </Expander>

                        <!-- DeepSeek -->
                        <Expander HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Tag="DeepSeek">
                            <Expander.Header>
                                <Grid>
                                    <TextBlock Text="DeepSeek"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="DeepSeekStatusText"
                                            Text="✓"
                                            FontWeight="SemiBold"
                                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                            HorizontalAlignment="Right"
                                            Margin="0,0,8,0"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="12"
                                    Padding="0,8">
                                <StackPanel Width="350"
                                            HorizontalAlignment="Left"
                                            Spacing="4">
                                    <TextBlock x:Name="DeepSeekKeyHeaderText"
                                               Text="API Key"
                                               FontSize="14"/>
                                    <Grid>
                                        <PasswordBox x:Name="DeepSeekKeyBox"
                                                     HorizontalAlignment="Stretch"
                                                     Padding="12,5,40,5"
                                                     PlaceholderText="sk-..."
                                                     PasswordRevealMode="Hidden"/>
                                        <Button x:Name="DeepSeekKeyRevealButton"
                                                AutomationProperties.AutomationId="DeepSeekKeyRevealButton"
                                                Style="{StaticResource SettingsInlineIconButtonStyle}"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,0,6,0"
                                                Tag="{Binding ElementName=DeepSeekKeyBox}"
                                                Click="OnPasswordRevealButtonClick">
                                            <FontIcon Glyph="&#xE890;"
                                                      FontSize="14"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                                <ComboBox x:Name="DeepSeekModelCombo"
                                        Header="Model"
                                        Width="280"
                                        IsEditable="True">
                                    <ComboBoxItem Content="deepseek-chat"
