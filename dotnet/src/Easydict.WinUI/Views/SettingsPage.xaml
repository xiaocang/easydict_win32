                                    <ComboBoxItem Content="Français"
                                            Tag="fr-FR"/>
                                    <ComboBoxItem Content="Deutsch"
                                            Tag="de-DE"/>
                                    <ComboBoxItem Content="Tiếng Việt"
                                            Tag="vi-VN"/>
                                    <ComboBoxItem Content="ไทย"
                                            Tag="th-TH"/>
                                    <ComboBoxItem Content="العربية"
                                            Tag="ar-SA"/>
                                    <ComboBoxItem Content="Bahasa Indonesia"
                                            Tag="id-ID"/>
                                    <ComboBoxItem Content="Italiano"
                                            Tag="it-IT"/>
                                    <ComboBoxItem Content="Bahasa Melayu"
                                            Tag="ms-MY"/>
                                    <ComboBoxItem Content="हिन्दी"
