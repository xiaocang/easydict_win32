                            HorizontalAlignment="Left">
                            <!-- Populated dynamically in code-behind -->
                        </ComboBox>

                                <!-- Second Language -->
                                <ComboBox
                                    x:Name="SecondLanguageCombo"
                                    Header="Second Language"
                                    Width="250"
                                    HorizontalAlignment="Left">
                                    <!-- Populated dynamically in code-behind -->
                                </ComboBox>

